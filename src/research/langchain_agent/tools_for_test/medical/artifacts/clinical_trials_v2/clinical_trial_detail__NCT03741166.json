      "primaryOutcomes": [
        {
          "measure": "Blood-based biomarkers associated with genetic and epigenetic alterations.",
          "description": "Biomarkers under evaluation include differential methylation of nucleic acids and altered expression of proteins in blood from subjects at average risk for development of colorectal cancer.",
          "timeFrame": "Point in time blood collection (1 day) at enrollment"
        }
      ]
    },
